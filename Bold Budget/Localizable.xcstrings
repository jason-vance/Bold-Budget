    },
    "%@\nAre you sure you want to delete this budget? It will no longer be accessible by you or anyone else. All of its transaction data will also be deleted. It will not be recoverable." : {

    },
    "%@ left" : {
      "comment" : "A label indicating how much more money is needed to reach the limit for a given category. The argument is the amount needed to reach the limit.",
      "isCommentAutoGenerated" : true
    },
    "%@ over goal!" : {
      "comment" : "A label indicating that their spending in a given category is higher than the category's spending goal.",
      "isCommentAutoGenerated" : true
    },
    "%@ over limit!" : {
      "comment" : "A text label indicating that a given expense category's total exceeds its limit. The argument is the amount by which the total exceeds the limit.",
      "isCommentAutoGenerated" : true
    },
    "%@ to go" : {
      "comment" : "A button-like label that appears when a user's savings goal is nearing completion. The text inside the button is the amount remaining to reach the goal.",
      "isCommentAutoGenerated" : true
    },
    "%@: %@/%@" : {
      "comment" : "A label displaying a goal or limit amount for a category over a specific time frame. The first argument is the type of goal or limit (\"Goal\" or \"Limit\"). The second argument is the formatted amount of the goal or limit. The third argument is the formatted time frame (e.g. \"week\").",
      "isCommentAutoGenerated" : true,
      "localizations" : {
